#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="$HOME/backup"
TIMESTAMP=$(date +"%Y_%m_%d_%H%M")

NOZIP=0
SOURCES=()

# ---- parse args ----
for arg in "$@"; do
    case "$arg" in
        --nozip)
            NOZIP=1
            ;;
        *)
            SOURCES+=("$arg")
            ;;
    esac
done

# ---- usage ----
if [ "${#SOURCES[@]}" -eq 0 ]; then
    echo "Usage: $0 <file_or_dir> [more_files_or_dirs...] [--nozip]"
    exit 1
fi

mkdir -p "$BACKUP_DIR"

# ---- backup loop ----
for src in "${SOURCES[@]}"; do
    if [ ! -e "$src" ]; then
        echo "Error: '$src' does not exist."
        continue
    fi

    base=$(basename "$src")
    dest="$BACKUP_DIR/${base}.${TIMESTAMP}.bak"

    # If the --nozip option is provided, perform a regular copy
    if [ "$NOZIP" -eq 1 ]; then
        if [ -d "$src" ]; then
            cp -a "$src" "$dest"
        else
            cp "$src" "$dest"
        fi
        echo "Backed up (no zip): $src -> $dest"
    else
        if [ -d "$src" ]; then
            zip -r -q "${dest}.zip" "$src"
            echo "Backed up (zip): $src -> ${dest}.zip"
        else
            zip -q "${dest}.zip" "$src"
            echo "Backed up (zip): $src -> ${dest}.zip"
        fi
    fi
done
